함수 타임스탐프ISO변환(타임스탐프: 숫자) → 문자열 {
  // 실제 구현: new Date(타임스탐프 * 1000).toISOString()
}

// 날짜 객체 생성 (연, 월, 일)
함수 날짜생성(연: 숫자, 월: 숫자, 일: 숫자) → 숫자 {
  // 실제 구현: new Date(연, 월-1, 일).getTime() / 1000
  // 주의: 월은 1~12 (JavaScript는 0~11)
}

// ============================================================
// 📊 3. 날짜 요소 추출
// ============================================================

// 타임스탐프에서 연도 추출
함수 연도추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getFullYear()
}

// 타임스탐프에서 월 추출 (1~12)
함수 월추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getMonth() + 1
}

// 타임스탐프에서 일 추출 (1~31)
함수 일추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getDate()
}

// 타임스탐프에서 시간 추출 (0~23)
함수 시간추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getHours()
}

// 타임스탐프에서 분 추출 (0~59)
함수 분추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getMinutes()
}

// 타임스탐프에서 초 추출 (0~59)
함수 초추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getSeconds()
}

// 타임스탐프에서 요일 추출 (0=일, 1=월, ..., 6=토)
함수 요일추출(타임스탐프: 숫자) → 숫자 {
  // 실제 구현: new Date(타임스탐프 * 1000).getDay()
}

// ============================================================
// 🔄 4. 날짜 계산 (Date Arithmetic)
// ============================================================

// N일 더하기
함수 일더하기(타임스탐프: 숫자, 일수: 숫자) → 숫자 {
  반환 타임스탐프 + (일수 * 86400)  // 86400초 = 1일
}

// N일 빼기
함수 일빼기(타임스탐프: 숫자, 일수: 숫자) → 숫자 {
  반환 타임스탐프 - (일수 * 86400)
}

// N시간 더하기
함수 시간더하기(타임스탐프: 숫자, 시간수: 숫자) → 숫자 {
  반환 타임스탐프 + (시간수 * 3600)  // 3600초 = 1시간
}

// N분 더하기
함수 분더하기(타임스탐프: 숫자, 분수: 숫자) → 숫자 {
  반환 타임스탐프 + (분수 * 60)
}

// 두 타임스탐프의 일차 계산
함수 일차계산(타임스탐프1: 숫자, 타임스탐프2: 숫자) → 숫자 {
  변수 차이 = 타임스탐프2 - 타임스탐프1
  반환 차이 / 86400  // 86400초 = 1일
}

// ============================================================
// 🎯 5. 날짜 포맷팅
// ============================================================

// 타임스탐프를 "YYYY-MM-DD" 형식으로 변환
함수 날짜포맷(타임스탐프: 숫자) → 문자열 {
  변수 연 = 연도추출(타임스탐프)
  변수 월 = 월추출(타임스탐프)
  변수 일 = 일추출(타임스탐프)

  변수 월str = 월
  만약 월 < 10 { 월str = "0" + 월 }

  변수 일str = 일
  만약 일 < 10 { 일str = "0" + 일 }

  반환 연 + "-" + 월str + "-" + 일str
}

// 타임스탐프를 "HH:MM:SS" 형식으로 변환
함수 시간포맷(타임스탐프: 숫자) → 문자열 {
  변수 시 = 시간추출(타임스탐프)
  변수 분 = 분추출(타임스탐프)
  변수 초 = 초추출(타임스탐프)

  변수 시str = 시
  만약 시 < 10 { 시str = "0" + 시 }

  변수 분str = 분
  만약 분 < 10 { 분str = "0" + 분 }

  변수 초str = 초
  만약 초 < 10 { 초str = "0" + 초 }

  반환 시str + ":" + 분str + ":" + 초str
}

// 타임스탐프를 "YYYY-MM-DD HH:MM:SS" 형식으로 변환
함수 날짜시간포맷(타임스탐프: 숫자) → 문자열 {
  반환 날짜포맷(타임스탐프) + " " + 시간포맷(타임스탐프)
}

