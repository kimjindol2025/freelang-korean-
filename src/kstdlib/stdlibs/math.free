/**
 * K-StdLib: 수학 모듈
 * 기본 수학 함수들
 */

공개 모듈 수학 {
  상수 PI = 3.14159265359
  상수 E = 2.71828182846

  함수 절대값(x: 숫자) -> 숫자 {
    만약 x < 0 {
      반환 0 - x
    }
    반환 x
  }

  함수 최대값(a: 숫자, b: 숫자) -> 숫자 {
    만약 a > b {
      반환 a
    }
    반환 b
  }

  함수 최소값(a: 숫자, b: 숫자) -> 숫자 {
    만약 a < b {
      반환 a
    }
    반환 b
  }

  함수 거듭제곱(밑: 숫자, 지수: 숫자) -> 숫자 {
    변수 결과 = 1
    변수 i = 0
    반복 i = 0; i < 지수; i = i + 1 {
      결과 = 결과 * 밑
    }
    반환 결과
  }
}
