// ============================================================
// 📋 5. 포맷팅 유틸
// ============================================================

// 들여쓰기 문자열 생성
함수 들여쓰기(수준: 숫자) → 문자열 {
  변수 result = ""
  반복 변수 i = 0; i < 수준; i = i + 1 {
    result = result + "  "  // 2칸 들여쓰기
  }
  반환 result
}

// 테이블 형식 출력
함수 테이블출력(헤더: 배열<문자열>, 행들: 배열<배열<문자열>>) → 공집합 {
  // 헤더 출력
  변수 헤더str = ""
  반복 변수 h = 0; h < 길이(헤더); h = h + 1 {
    만약 h > 0 { 헤더str = 헤더str + " | " }
    헤더str = 헤더str + 헤더[h]
  }
  출력(헤더str)

  // 각 행 출력
  반복 변수 r = 0; r < 길이(행들); r = r + 1 {
    변수 행 = 행들[r]
    변수 행str = ""
    반복 변수 c = 0; c < 길이(행); c = c + 1 {
      만약 c > 0 { 행str = 행str + " | " }
      행str = 행str + 행[c]
    }
    출력(행str)
  }
}

// ============================================================
// 🎨 6. 색상 지원 (ANSI Color Codes)
// ============================================================

// 색상 코드 상수
상수 색상_빨강 = "\u001b[31m"
상수 색상_초록 = "\u001b[32m"
상수 색상_노랑 = "\u001b[33m"
상수 색상_파랑 = "\u001b[34m"
상수 색상_초기화 = "\u001b[0m"

// 색상 문자열 생성
함수 색상문자열(텍스트: 문자열, 색: 문자열) → 문자열 {
  반환 색 + 텍스트 + 색상_초기화
}

// 성공 메시지 (초록)
함수 성공메시지(메시지: 문자열) → 공집합 {
  출력(색상_초록 + "✓ " + 메시지 + 색상_초기화)
}

// 오류 메시지 (빨강)
함수 오류메시지(메시지: 문자열) → 공집합 {
  출력(색상_빨강 + "✗ " + 메시지 + 색상_초기화)
}

// 경고 메시지 (노랑)
함수 경고메시지(메시지: 문자열) → 공집합 {
  출력(색상_노랑 + "⚠ " + 메시지 + 색상_초기화)
}

