// ============================================================
// 5. 암호 보안
// ============================================================

// 비밀번호 강도 검사
함수 비밀번호_강도검사(비밀번호: 문자열) → 숫자 {
  // 반환값: 0-100 (약함~매우강함)
  변수 점수 = 0
  변수 길이 = 비밀번호.len
  
  // 길이 점수 (최대 40점)
  만약 길이 >= 8 { 점수 = 점수 + 10 }
  만약 길이 >= 12 { 점수 = 점수 + 10 }
  만약 길이 >= 16 { 점수 = 점수 + 20 }
  
  // 문자 다양성 점수 (최대 60점)
  만약 비밀번호.toUpperCase() != 비밀번호 { 점수 = 점수 + 15 }  // 대문자
  만약 비밀번호.toLowerCase() != 비밀번호 { 점수 = 점수 + 15 }  // 소문자
  만약 비밀번호.includes("0") 아니면 비밀번호.includes("1") { 점수 = 점수 + 15 }  // 숫자
  만약 비밀번호.includes("!") 아니면 비밀번호.includes("@") { 점수 = 점수 + 15 }  // 특수문자
  
  반환 점수
}

