// ┌─────────────────────────────────────────────────────────────┐
// │ K-FreeLang IR Generator (중간코드 생성기)                    │
// │ AST → IR 변환 (2026-03-27)                                   │
// └─────────────────────────────────────────────────────────────┘

// ============================================================
// 🔧 1. IR 기본 구조
// ============================================================

// IR 명령어 타입
열거형 IRInstructionType {
  // 기본 연산
  LoadConst,      // 상수 로드
  LoadVar,        // 변수 로드
  StoreVar,       // 변수 저장
  LoadGlobal,     // 전역 변수 로드
  StoreGlobal,    // 전역 변수 저장

  // 산술/논리 연산
  Add,            // +
  Sub,            // -
  Mul,            // *
  Div,            // /
  Mod,            // %
  Eq,             // ==
  Ne,             // !=
  Lt,             // <
  Le,             // <=
  Gt,             // >
  Ge,             // >=
  And,            // &&
  Or,             // ||
  Not,            // !

  // 제어 흐름
  Jump,           // 무조건 점프
  JumpIfFalse,    // 거짓이면 점프
  JumpIfTrue,     // 참이면 점프
  Call,           // 함수 호출
  Return,         // 반환
  Throw,          // 예외 던지기

  // 배열/객체
  CreateArray,    // 배열 생성
  CreateObject,   // 객체 생성
  IndexGet,       // 배열/객체 인덱싱
  IndexSet,       // 배열/객체 설정
  FieldGet,       // 필드 접근
  FieldSet,       // 필드 설정

  // 함수 관련
  DefineFunction, // 함수 정의
  DefineClass,    // 클래스 정의
  DefineEnum,     // 열거형 정의
  DefineTrait,    // 특성 정의
  Impl,           // impl 블록

  // 타입 관련
  Cast,           // 타입 변환
  TypeOf,         // 타입 확인

  // 기타
  Nop,            // 아무것도 하지 않음
  Label,          // 라벨 정의
}

// IR 명령어
구조체 IRInstruction {
  타입: IRInstructionType,
  피연산자들: 배열<문자열>,  // 추가 정보 저장
  행번호: 숫자,
  열번호: 숫자,
}

// IR 블록 (기본 블록)
구조체 IRBlock {
  라벨: 문자열,
  명령어들: 배열<IRInstruction>,
  다음블록: 문자열,      // 다음 블록 라벨
  분기블록: 문자열,      // 조건부 분기 라벨
}

// IR 프로그램
구조체 IRProgram {
  이름: 문자열,
  블록들: 맵<문자열, IRBlock>,
  함수들: 맵<문자열, IRFunction>,
  전역변수들: 맵<문자열, 타입정보>,
  시작블록: 문자열,
}

// IR 함수
구조체 IRFunction {
  이름: 문자열,
  매개변수들: 배열<매개변수>,
  반환타입: 타입정보,
  블록들: 맵<문자열, IRBlock>,
  시작블록: 문자열,
}

구조체 매개변수 {
  이름: 문자열,
  타입: 타입정보,
}

구조체 타입정보 {
  이름: 문자열,
  기본타입: 문자열,  // "number" | "string" | "bool" | "array" | "object"
  제네릭인자들: 배열<타입정보>,
}

// ============================================================
// 🔧 2. IR 생성기 클래스
// ============================================================

함수 IRGenerator_생성() → 맵<문자열, 공집합> {
  변수 생성기 = {
    블록들: {},
    함수들: {},
    현재블록: "entry",
    블록카운터: 0,
    라벨카운터: 0,
    반환: 공집합
  }
  반환 생성기
}

