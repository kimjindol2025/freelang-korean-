// ┌──────────────────────────────────────────────────────┐
// │ 한글 식별자 테스트                                     │
// │ 한글 변수명과 함수명 지원 검증                         │
// │ (2026-03-27)                                         │
// └──────────────────────────────────────────────────────┘

// ============================================================
// 1. 한글 변수명 테스트
// ============================================================

변수 사용자이름 = "김철수"
변수 사용자나이 = 30
변수 사용자활성 = 참
변수 월급액 = 5000000

// ============================================================
// 2. 한글 함수명 테스트
// ============================================================

함수 나이검증(입력나이: 숫자) → 참거짓 {
  반환 입력나이 >= 18 아니면 입력나이 <= 100
}

함수 급여계산(기본급: 숫자, 보너스: 숫자) → 숫자 {
  반환 기본급 + 보너스
}

함수 사용자정보출력(이름: 문자열, 나이: 숫자) {
  출력(이름)
  출력(나이)
}

// ============================================================
// 3. 한글 상수 테스트
// ============================================================

상수 기본세율 = 0.03
상수 최소나이 = 18
상수 회사명 = "한국소프트웨어"

// ============================================================
// 4. 한글 배열/객체 테스트
// ============================================================

변수 직원목록 = ["김철수", "이영희", "박준호"]
변수 급여정보 = {
  이름: "김철수",
  직급: "개발자",
  연봉: 50000000
}

// ============================================================
// 5. 실행 코드
// ============================================================

출력("=== 한글 식별자 테스트 시작 ===")
출력("")

// 변수 테스트
출력("사용자이름: " + 사용자이름)
출력("사용자나이: " + 사용자나이)
출력("사용자활성: " + 사용자활성)
출력("")

// 함수 테스트
변수 연령검증결과 = 나이검증(사용자나이)
출력("나이검증(" + 사용자나이 + "): " + 연령검증결과)
출력("")

// 급여 계산
변수 총급여 = 급여계산(월급액, 200000)
출력("총급여: " + 총급여)
출력("")

// 함수 호출
사용자정보출력(사용자이름, 사용자나이)
출력("")

// 배열 출력
출력("직원목록: " + 직원목록)
출력("")

출력("=== 한글 식별자 테스트 완료 ===")
