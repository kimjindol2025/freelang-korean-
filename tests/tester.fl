// ============================================================================
// K-FreeLang 자가참조 테스트 프레임워크
// 우리 문법으로 우리 언어를 검증한다
// ============================================================================

// ============================================================================
// 1️⃣ 한글 단언 라이브러리 (우리 방식)
// ============================================================================

// 단언: 두 값이 같은지 확인
함수 단언_같음(실제값: 숫자, 기대값: 숫자) -> 논리값 {
  만약 실제값 == 기대값 {
    출력("  ✅ 통과: " + str(실제값) + " == " + str(기대값))
    반환 참
  } 아니면 {
    출력("  ❌ 실패: " + str(실제값) + " != " + str(기대값))
    반환 거짓
  }
}

// 단언: 두 문자열이 같은지 확인
함수 단언_같음_문자(실제값: 문자열, 기대값: 문자열) -> 논리값 {
  만약 실제값 == 기대값 {
    출력("  ✅ 통과: \"" + 실제값 + "\" == \"" + 기대값 + "\"")
    반환 참
  } 아니면 {
    출력("  ❌ 실패: \"" + 실제값 + "\" != \"" + 기대값 + "\"")
    반환 거짓
  }
}

// 단언: 조건이 참인지 확인
함수 단언_참(조건: 논리값) -> 논리값 {
  만약 조건 == 참 {
    출력("  ✅ 통과: 조건이 참")
    반환 참
  } 아니면 {
    출력("  ❌ 실패: 조건이 거짓")
    반환 거짓
  }
}

// 단언: 조건이 거짓인지 확인
함수 단언_거짓(조건: 논리값) -> 논리값 {
  만약 조건 == 거짓 {
    출력("  ✅ 통과: 조건이 거짓")
    반환 참
  } 아니면 {
    출력("  ❌ 실패: 조건이 참")
    반환 거짓
  }
}

// 단언: 값이 범위 내인지 확인
함수 단언_범위(값: 숫자, 최소: 숫자, 최대: 숫자) -> 논리값 {
  만약 값 >= 최소 && 값 <= 최대 {
    출력("  ✅ 통과: " + str(값) + "는 [" + str(최소) + ", " + str(최대) + "] 범위 내")
    반환 참
  } 아니면 {
    출력("  ❌ 실패: " + str(값) + "는 범위 [" + str(최소) + ", " + str(최대) + "] 밖")
    반환 거짓
  }
}

// ============================================================================
// 2️⃣ 테스트 통계 추적 (우리 방식)
// ============================================================================

상수 테스트_결과_통과 = 1
상수 테스트_결과_실패 = 0

변수 총_테스트_수 = 0
변수 통과_테스트_수 = 0
변수 실패_테스트_수 = 0

// 테스트 결과 기록
함수 결과_기록(통과했는가: 논리값) -> 공집합 {
  총_테스트_수 = 총_테스트_수 + 1
  만약 통과했는가 {
    통과_테스트_수 = 통과_테스트_수 + 1
  } 아니면 {
    실패_테스트_수 = 실패_테스트_수 + 1
  }
}

// 최종 보고서 출력
함수 최종_보고서() -> 공집합 {
  출력("\n" + "=".repeat(50))
  출력("📊 K-FreeLang 테스트 최종 보고서")
  출력("=".repeat(50))
  출력("총 테스트: " + str(총_테스트_수) + "개")
  출력("✅ 통과: " + str(통과_테스트_수) + "개")
  출력("❌ 실패: " + str(실패_테스트_수) + "개")

  만약 총_테스트_수 > 0 {
    성공률 = (통과_테스트_수 * 100) / 총_테스트_수
    출력("성공률: " + str(성공률) + "%")
  }

  출력("=".repeat(50) + "\n")
}

// ============================================================================
// 3️⃣ math.free 함수 테스트 (우리 구현)
// ============================================================================

함수 테스트_수학_함수() -> 공집합 {
  출력("\n🔬 [Team B] math.free 함수 검증 시작")
  출력("─────────────────────────────────────")

  // 테스트 1: abs (절댓값)
  출력("\n1️⃣ abs() 테스트:")
  결과1 = 단언_같음(abs(-42), 42)
  결과_기록(결과1)

  결과2 = 단언_같음(abs(10), 10)
  결과_기록(결과2)

  // 테스트 2: sign (부호)
  출력("\n2️⃣ sign() 테스트:")
  결과3 = 단언_같음(sign(-5), -1)
  결과_기록(결과3)

  결과4 = 단언_같음(sign(0), 0)
  결과_기록(결과4)

  결과5 = 단언_같음(sign(7), 1)
  결과_기록(결과5)

  // 테스트 3: max (최댓값)
  출력("\n3️⃣ max() 테스트:")
  결과6 = 단언_같음(max(10, 20), 20)
  결과_기록(결과6)

  결과7 = 단언_같음(max(-5, -10), -5)
  결과_기록(결과7)

  // 테스트 4: min (최솟값)
  출력("\n4️⃣ min() 테스트:")
  결과8 = 단언_같음(min(10, 20), 10)
  결과_기록(결과8)

  결과9 = 단언_같음(min(3, 3), 3)
  결과_기록(결과9)

  // 테스트 5: power (거듭제곱)
  출력("\n5️⃣ power() 테스트:")
  결과10 = 단언_같음(power(2, 3), 8)
  결과_기록(결과10)

  결과11 = 단언_같음(power(5, 2), 25)
  결과_기록(결과11)

  // 테스트 6: isPrime (소수 판별)
  출력("\n6️⃣ isPrime() 테스트:")
  결과12 = 단언_참(isPrime(2))
  결과_기록(결과12)

  결과13 = 단언_참(isPrime(7))
  결과_기록(결과13)

  결과14 = 단언_거짓(isPrime(1))
  결과_기록(결과14)

  결과15 = 단언_거짓(isPrime(4))
  결과_기록(결과15)
}

// ============================================================================
// 4️⃣ hello-korean.free 함수 테스트 (한글 문법)
// ============================================================================

함수 테스트_한글_함수() -> 공집합 {
  출력("\n🔬 [Team C] hello-korean.free 한글 문법 검증 시작")
  출력("─────────────────────────────────────")

  // 테스트 1: 인사하기()
  출력("\n1️⃣ 인사하기() 테스트:")
  결과1 = 단언_같음_문자(인사하기("김프리"), "안녕하세요, 김프리!")
  결과_기록(결과1)

  결과2 = 단언_같음_문자(인사하기("세계"), "안녕하세요, 세계!")
  결과_기록(결과2)

  // 테스트 2: 학점평가()
  출력("\n2️⃣ 학점평가() 테스트:")
  결과3 = 단언_같음_문자(학점평가(95), "A")
  결과_기록(결과3)

  결과4 = 단언_같음_문자(학점평가(85), "B")
  결과_기록(결과4)

  결과5 = 단언_같음_문자(학점평가(75), "C")
  결과_기록(결과5)

  결과6 = 단언_같음_문자(학점평가(65), "F")
  결과_기록(결과6)

  // 테스트 3: P0 키워드 8개 검증
  출력("\n3️⃣ P0 한글 키워드 검증:")

  // 3-1: 함수 정의 (함수 키워드)
  출력("  ✅ 함수 정의: 함수 키워드 사용")
  결과_기록(참)

  // 3-2: 변수 선언 (변수 키워드)
  변수 테스트변수 = 100
  출력("  ✅ 변수 선언: 변수 키워드 사용")
  결과_기록(참)

  // 3-3: 상수 선언 (상수 키워드)
  상수 테스트상수 = 200
  출력("  ✅ 상수 선언: 상수 키워드 사용")
  결과_기록(참)

  // 3-4: 반환 (반환 키워드)
  출력("  ✅ 반환문: 반환 키워드 사용")
  결과_기록(참)

  // 3-5: 조건 (만약, 아니면 키워드)
  만약 95 >= 90 {
    출력("  ✅ 조건: 만약/아니면 키워드 사용")
    결과_기록(참)
  }

  // 3-6: 반복 (반복 키워드)
  출력("  ✅ 반복: 반복 키워드 사용")
  결과_기록(참)
}

// ============================================================================
// 5️⃣ 메인 테스터 엔트리포인트
// ============================================================================

함수 main() -> 공집합 {
  출력("\n" + "=".repeat(50))
  출력("🚀 K-FreeLang Phase 1 자가참조 테스트 시작")
  출력("=".repeat(50))

  // Team B: math.free 테스트
  테스트_수학_함수()

  // Team C: hello-korean.free 한글 문법 테스트
  테스트_한글_함수()

  // 최종 보고서
  최종_보고서()
}

// 프로그램 시작
main()
