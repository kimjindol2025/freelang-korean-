// ┌─────────────────────────────────────────────────────────────┐
// │ K-FreeLang 모듈 시스템 & 빌트인 메서드 테스트                │
// │ (2026-03-27)                                                 │
// └─────────────────────────────────────────────────────────────┘

// ============================================================
// 1. 빌트인 메서드 테스트: 배열
// ============================================================

테스트 빌트인_배열_길이 {
  변수 배열 = [1, 2, 3, 4, 5]
  변수 길이 = 배열.len
  검증(길이 == 5, "배열 길이 반환 실패")
  출력("✓ 빌트인: 배열.len")
}

테스트 빌트인_배열_추가 {
  변수 배열 = [1, 2, 3]
  배열.push(4)
  검증(배열.len == 4, "배열.push 실패")
  검증(배열[3] == 4, "마지막 요소 확인 실패")
  출력("✓ 빌트인: 배열.push")
}

테스트 빌트인_배열_제거 {
  변수 배열 = [1, 2, 3, 4, 5]
  변수 마지막 = 배열.pop()
  검증(마지막 == 5, "배열.pop 실패")
  검증(배열.len == 4, "제거 후 길이 실패")
  출력("✓ 빌트인: 배열.pop")
}

테스트 빌트인_배열_결합 {
  변수 배열1 = [1, 2]
  변수 배열2 = [3, 4]
  변수 결합 = 배열1.concat(배열2)
  검증(결합.len == 4, "concat 길이 실패")
  검증(결합[2] == 3, "concat 요소 확인 실패")
  출력("✓ 빌트인: 배열.concat")
}

테스트 빌트인_배열_포함 {
  변수 배열 = [1, 2, 3, 4, 5]
  변수 있음 = 배열.includes(3)
  검증(있음, "배열.includes 실패")
  출력("✓ 빌트인: 배열.includes")
}

테스트 빌트인_배열_위치 {
  변수 배열 = [10, 20, 30, 40]
  변수 위치 = 배열.indexOf(30)
  검증(위치 == 2, "배열.indexOf 실패")
  출력("✓ 빌트인: 배열.indexOf")
}

// ============================================================
// 2. 빌트인 메서드 테스트: 문자열
// ============================================================

테스트 빌트인_문자열_길이 {
  변수 문자열 = "안녕하세요"
  변수 길이 = 문자열.len
  검증(길이 == 5, "문자열 길이 반환 실패")
  출력("✓ 빌트인: 문자열.len")
}

테스트 빌트인_문자열_대문자 {
  변수 문자열 = "hello"
  변수 대문자 = 문자열.toUpperCase()
  검증(대문자 == "HELLO", "toUpperCase 실패")
  출력("✓ 빌트인: 문자열.toUpperCase")
}

테스트 빌트인_문자열_소문자 {
  변수 문자열 = "WORLD"
  변수 소문자 = 문자열.toLowerCase()
  검증(소문자 == "world", "toLowerCase 실패")
  출력("✓ 빌트인: 문자열.toLowerCase")
}

테스트 빌트인_문자열_분할 {
  변수 문자열 = "a,b,c"
  변수 배열 = 문자열.split(",")
  검증(배열.len == 3, "split 길이 실패")
  검증(배열[0] == "a", "split 요소 실패")
  출력("✓ 빌트인: 문자열.split")
}

테스트 빌트인_문자열_포함 {
  변수 문자열 = "hello world"
  변수 있음 = 문자열.includes("world")
  검증(있음, "문자열.includes 실패")
  출력("✓ 빌트인: 문자열.includes")
}

테스트 빌트인_문자열_시작 {
  변수 문자열 = "hello world"
  변수 시작함 = 문자열.startsWith("hello")
  검증(시작함, "startsWith 실패")
  출력("✓ 빌트인: 문자열.startsWith")
}

테스트 빌트인_문자열_끝 {
  변수 문자열 = "hello world"
  변수 끝남 = 문자열.endsWith("world")
  검증(끝남, "endsWith 실패")
  출력("✓ 빌트인: 문자열.endsWith")
}

테스트 빌트인_문자열_반복 {
  변수 문자열 = "ha"
  변수 반복 = 문자열.repeat(3)
  검증(반복 == "hahaha", "repeat 실패")
  출력("✓ 빌트인: 문자열.repeat")
}

// ============================================================
// 3. 모듈 선언 & 접근
// ============================================================

모듈 수학 {
  함수 더하기(a: 숫자, b: 숫자) → 숫자 {
    반환 a + b
  }

  함수 빼기(a: 숫자, b: 숫자) → 숫자 {
    반환 a - b
  }

  변수 파이 = 3.14159
}

테스트 모듈_멤버접근 {
  변수 합 = 수학.더하기(10, 20)
  검증(합 == 30, "모듈.함수 호출 실패")
  출력("✓ 모듈: 모듈.더하기")
}

테스트 모듈_변수접근 {
  변수 값 = 수학.파이
  검증(값 > 3, "모듈 변수 접근 실패")
  출력("✓ 모듈: 모듈.파이")
}

// ============================================================
// 4. 중첩 멤버 접근
// ============================================================

테스트 중첩_멤버_배열요소 {
  변수 데이터 = [[1, 2], [3, 4], [5, 6]]
  변수 첫번째 = 데이터[0]
  변수 길이 = 첫번째.len
  검증(길이 == 2, "중첩 배열 길이 실패")
  출력("✓ 중첩: 배열 요소 길이")
}

테스트 중첩_멤버_객체속성 {
  변수 사람 = {
    이름: "김",
    나이: 25,
    도시: "서울"
  }
  변수 이름 = 사람["이름"]
  검증(이름 == "김", "객체 속성 접근 실패")
  출력("✓ 중첩: 객체 속성 접근")
}

// ============================================================
// 5. 체이닝: 메서드 연속 호출
// ============================================================

테스트 메서드_체이닝_배열 {
  변수 배열 = [1, 2, 3, 4, 5]
  // map(x => x * 2).filter(x => x > 4)
  변수 맵된배열 = 배열.map(함수(x) {
    반환 x * 2
  })
  변수 필터된 = 맵된배열.filter(함수(x) {
    반환 x > 4
  })
  검증(필터된.len == 4, "체이닝 필터 실패")
  출력("✓ 체이닝: 배열.map.filter")
}

테스트 메서드_체이닝_문자열 {
  변수 문자열 = "  hello world  "
  변수 정리됨 = 문자열.trim().toUpperCase()
  검증(정리됨 == "HELLO WORLD", "문자열 체이닝 실패")
  출력("✓ 체이닝: 문자열.trim().toUpperCase()")
}

// ============================================================
// 6. 모듈과 메서드 조합
// ============================================================

모듈 문자열유틸 {
  함수 역순(str: 문자열) → 문자열 {
    // 간단한 역순 (실제로는 더 복잡함)
    반환 str
  }

  함수 반복(str: 문자열, n: 숫자) → 문자열 {
    반환 str.repeat(n)
  }
}

테스트 모듈과_메서드_조합 {
  변수 결과 = 문자열유틸.반복("ok", 3)
  변수 길이 = 결과.len
  검증(길이 > 0, "모듈 메서드 조합 실패")
  출력("✓ 조합: 모듈.함수() → 메서드")
}

// ============================================================
// 최종 요약
// ============================================================

출력("
┌─────────────────────────────────────────┐
│ ✅ 모듈 시스템 & 빌트인 메서드 테스트   │
│    모두 완료!                            │
└─────────────────────────────────────────┘
")
